# ─── PostgreSQL ───────────────────────────────────────────────
# Pour Render PostgreSQL, utilisez DATABASE_URL.
DATABASE_URL=postgres://user:password@host:port/database

# Optionnel si vous utilisez des variables DB séparées
DB_HOST=localhost
DB_PORT=5432
DB_NAME=douala
DB_USER=postgres
DB_PASSWORD=....

# ─── Serveur ──────────────────────────────────────────────────
PORT=3000

# ─── CORS - IMPORTANT POUR DONNÉES MOBILES ────────────────────
# Ajouter votre domaine Vercel exactement comme il apparaît
# En local: http://localhost:5173,http://localhost:3000
# En prod: https://votre-domaine.vercel.app,https://www.votre-domaine.vercel.app
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Frontend/Vercel
FRONTEND_URL=http://localhost:5173

